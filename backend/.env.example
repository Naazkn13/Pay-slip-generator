# Flask environment: 'development' or 'production'
FLASK_ENV=production

# Server port (Railway/Render will set this automatically)
PORT=5000

# Allowed frontend origin for CORS (set to your Vercel URL in production)
# Example: https://payslip-generator.vercel.app
CORS_ORIGIN=*

# Max upload file size in MB
MAX_FILE_SIZE_MB=10
